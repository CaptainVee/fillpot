# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=fillpot.settings.local
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (production only)
DATABASE_URL=postgres://user:password@localhost:5432/fillpot

# Redis
REDIS_URL=redis://localhost:6379/0

# Nomba API
NOMBA_ACCOUNT_ID=your-account-id
NOMBA_CLIENT_ID=your-client-id
NOMBA_CLIENT_SECRET=your-client-secret
NOMBA_WEBHOOK_SECRET=NombaHackathon2026

# Email (Brevo SMTP — production only)
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-brevo-login
EMAIL_HOST_PASSWORD=your-brevo-smtp-key
